from sklearn.ensemble import RandomForestRegressor
from sklearn.metrics import mean_absolute_error, mean_squared_error, r2_score

rf = RandomForestRegressor(
    n_estimators=300,
    max_depth=20,
    random_state=42
)
rf.fit(X_train, y_train) # y_train is now log-transformed

rf_pred_log = rf.predict(X_test) # Predictions are on log scale

# Inverse transform predictions for evaluation on original scale
y_pred_original_scale_rf = np.expm1(rf_pred_log)
# y_test_original_scale is already calculated in the previous cell, use it for consistency.

mae_rf = mean_absolute_error(y_test_original_scale, y_pred_original_scale_rf)
rmse_rf = np.sqrt(mean_squared_error(y_test_original_scale, y_pred_original_scale_rf))
r2_rf = r2_score(y_test_original_scale, y_pred_original_scale_rf)

print("Random Forest MAE (original scale):", mae_rf)
print("Random Forest RMSE (original scale):", rmse_rf)
print("Random Forest R2 (original scale):", r2_rf)
